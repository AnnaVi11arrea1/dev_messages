{
  "manifest_version": 3,
  "name": "Dev.to Messages",
  "version": "1.0.9",
  "description": "Private direct messaging for Dev.to users with link safety and spam reporting.",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["https://dev.to/*", "https://*.vercel.app/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Dev.to Messages",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://dev.to/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
